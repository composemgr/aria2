# Aria2 - Download manager with web UI (AriaNg)
# Copy to app.env and fill in your values

# Timezone
TZ=America/New_York

# Hostname
BASE_HOST_NAME=$HOSTNAME

# User/group IDs for file permissions
SERVICE_USER=0
SERVICE_GROUP=0

# RPC secret token (used to connect AriaNg to aria2)
APP_SECRET_KEY=changeme_secret_key_min_32_chars
